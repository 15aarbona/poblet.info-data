---
import Layout from "../../layouts/Layout.astro";
import BarChart from "../../components/BarChart.astro";
import summary from "../../data/dashboard/summary.json";
import { aggregateCreators, slugMapForCreators, type SummaryPayload } from "../../lib/creators";

const s = summary as SummaryPayload;
const fmt = new Intl.NumberFormat("ca-ES");
const agg = aggregateCreators(s.creators);
const slugMap = slugMapForCreators(s.creators.map((c) => c.creador));
const barTop = agg.slice(0, 16);
const barSeg = [...agg]
  .filter((r) => r.seguidores > 0)
  .sort((a, b) => b.seguidores - a.seguidores)
  .slice(0, 16);
const hasSeguidores = barSeg.length > 0;
---

<Layout title="Creadors · Dashboard Poblet" description="Llista de creadors amb mètriques agregades">
  <div class="mb-8">
    <a href="/" class="text-sm text-zinc-500 hover:text-zinc-300">← Resum</a>
    <h1 class="mt-3 text-3xl font-bold text-white">Creadors</h1>
    <p class="mt-2 max-w-2xl text-sm text-zinc-400">
      Ordenats per visualitzacions totals (últim snapshot). Cada fila agrupa totes les xarxes on apareix el creador.
    </p>
  </div>

  {
    barTop.length > 0 && (
      <section class={`mb-10 grid gap-6 ${hasSeguidores ? "lg:grid-cols-2" : ""}`}>
        <BarChart
          labels={barTop.map((r) => r.creador)}
          values={barTop.map((r) => Math.round(r.visualizaciones))}
          title="Top creadors per visualitzacions (agregat)"
          horizontal={true}
          color="129, 140, 248"
        />
        {hasSeguidores && (
          <BarChart
            labels={barSeg.map((r) => r.creador)}
            values={barSeg.map((r) => Math.round(r.seguidores))}
            title="Top creadors per seguidors (suma de màx. per xarxa)"
            horizontal={true}
            color="34, 197, 94"
          />
        )}
      </section>
    )
  }

  <div class="overflow-hidden rounded-xl border border-zinc-800">
    <table class="w-full text-left text-sm">
      <thead class="border-b border-zinc-800 bg-zinc-900/80 text-xs uppercase text-zinc-500">
        <tr>
          <th class="px-4 py-3 font-medium">Creador</th>
          <th class="px-4 py-3 font-medium">Xarxes</th>
          <th class="px-4 py-3 font-medium text-right">Continguts</th>
          <th class="px-4 py-3 font-medium text-right">Visualitzacions</th>
          <th class="px-4 py-3 font-medium text-right">Seguidors</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-800">
        {
          agg.map((row) => (
            <tr class="hover:bg-zinc-900/50">
              <td class="px-4 py-3">
                <a
                  href={`/creadors/${slugMap.get(row.creador)!}`}
                  class="font-medium text-indigo-300 hover:text-indigo-200 hover:underline"
                >
                  {row.creador}
                </a>
              </td>
              <td class="px-4 py-3 text-zinc-400">{row.platforms}</td>
              <td class="px-4 py-3 text-right tabular-nums text-zinc-300">{fmt.format(row.content_count)}</td>
              <td class="px-4 py-3 text-right tabular-nums text-zinc-200">
                {fmt.format(Math.round(row.visualizaciones))}
              </td>
              <td class="px-4 py-3 text-right tabular-nums text-emerald-300/90">
                {row.seguidores > 0 ? fmt.format(Math.round(row.seguidores)) : "—"}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</Layout>
